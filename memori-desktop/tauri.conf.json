{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memori-Vault",
  "version": "0.1.0",
  "identifier": "com.memori.vault.desktop",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Memori-Vault",
