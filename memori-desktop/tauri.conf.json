{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memori-Vault",
  "version": "1.0.0",
  "identifier": "com.memori.vault.desktop",
  "build": {
    "beforeDevCommand": "cd ../ui && pnpm run dev",
    "beforeBuildCommand": "cd ../ui && pnpm run build",
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Memori-Vault",
        "width": 1480,
        "height": 920,
        "resizable": true,
        "transparent": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
