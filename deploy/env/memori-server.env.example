# Networking
MEMORI_SERVER_ADDR=0.0.0.0:3757

# Vault data root (watched docs, sqlite, audit logs are under config/data dirs)
MEMORI_WATCH_ROOT=/srv/memori/vault

# Runtime model defaults (local-first)
MEMORI_MODEL_PROVIDER=ollama_local
MEMORI_MODEL_ENDPOINT=http://127.0.0.1:11434
MEMORI_CHAT_MODEL=qwen2.5:7b
MEMORI_GRAPH_MODEL=qwen2.5:7b
MEMORI_EMBED_MODEL=nomic-embed-text:latest

# Optional remote API key fallback (only used if provider=openai_compatible)
# MEMORI_MODEL_API_KEY=replace_me
