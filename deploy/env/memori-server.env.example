# Networking
MEMORI_SERVER_ADDR=0.0.0.0:3757

# Required for protected HTTP APIs. Generate a long random value and send it as:
# Authorization: Bearer <MEMORI_SERVER_ADMIN_TOKEN>
MEMORI_SERVER_ADMIN_TOKEN=replace_with_at_least_24_random_chars

# Vault data root (watched docs, sqlite, audit logs are under config/data dirs)
MEMORI_WATCH_ROOT=/srv/memori/vault

# Runtime model defaults (local-first)
MEMORI_MODEL_PROVIDER=llama_cpp_local
MEMORI_CHAT_ENDPOINT=http://127.0.0.1:18001
MEMORI_GRAPH_ENDPOINT=http://127.0.0.1:18002
MEMORI_EMBED_ENDPOINT=http://127.0.0.1:18003
MEMORI_CHAT_MODEL=qwen3-14b
MEMORI_GRAPH_MODEL=qwen3-8b
MEMORI_EMBED_MODEL=Qwen3-Embedding-4B

# Optional remote API key fallback (only used if provider=openai_compatible)
# MEMORI_MODEL_API_KEY=replace_me

# Per-IP rate limiting (fixed 60s window). Defaults shown; set ENABLED=0 to disable.
# General endpoints: requests/min/IP. Auth & /api/admin: stricter requests/min/IP.
# MEMORI_RATE_LIMIT_ENABLED=1
# MEMORI_RATE_LIMIT_PER_MIN=600
# MEMORI_AUTH_RATE_LIMIT_PER_MIN=20
